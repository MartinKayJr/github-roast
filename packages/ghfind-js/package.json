{
  "name": "@hikariming/ghfind",
  "version": "0.1.1",
  "description": "Official SDK for ghsphere.com — score any GitHub account 0-100 for value & trustworthiness (deterministic, no LLM), plus roasts, battles, leaderboards, and developer discovery.",
  "keywords": [
    "github",
    "developer-score",
    "trust-score",
    "contribution",
    "leaderboard",
    "agent",
    "mcp",
    "ai",
    "ghfind"
  ],
  "homepage": "https://ghsphere.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinKayJr/github-roast.git",
    "directory": "packages/ghfind-js"
  },
  "bugs": {
    "url": "https://github.com/MartinKayJr/github-roast/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "ghsphere",
  "type": "module",
  "bin": {
    "ghfind": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "import": "./dist/local.js",
      "require": "./dist/local.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
